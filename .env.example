# Copy to .env and fill in real values (or just export these in your shell).
# Get the bot token from @BotFather:  Telegram -> @BotFather -> /newbot
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-here

# Get a free key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza-your-key-here

# SignalWire phone line (call.py / run_phone.py). Space -> API.
SIGNALWIRE_SPACE_URL=your-space.signalwire.com
SIGNALWIRE_PROJECT_ID=
SIGNALWIRE_API_TOKEN=
# Optional: exact number to configure, e.g. +14155551234. Blank = all your numbers.
SIGNALWIRE_PHONE_NUMBER=
# Auto-set by run_phone.py; only needed if you run call.py without the launcher.
PUBLIC_URL=
